# vello-llama-local config. Edit + `./vello-llama-local restart`.

# Ports
LLAMA_PORT=8080
WEBUI_PORT=3000

# Active model (managed by `./vello-llama-local models use`)
LLAMA_MODEL_FILE=Qwen2.5-7B-Instruct-Q5_K_M.gguf
LLAMA_MODEL_ALIAS=qwen2.5-7b-local

# Tuning
LLAMA_CTX=32768          # context window
LLAMA_NGL=99             # GPU layers (99 = all)
LLAMA_THREADS=6          # physical CPU cores (not SMT)
LLAMA_BATCH=2048
LLAMA_UBATCH=512

# Web UI
WEBUI_AUTH=False         # True if exposing to a network

# Default model for `./vello-llama-local install` (must be a key in catalog.json)
LOCAL_LLM_DEFAULT_MODEL=qwen2.5-7b
