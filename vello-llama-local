#!/usr/bin/env bash
# vello-llama-local — self-hosted LLM stack on your GPU
# https://github.com/Colgate13/vello-llama-local
#
# Single CLI entry point. Run `./vello-llama-local help` for usage.

set -euo pipefail

VERSION="0.1.0"
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$PROJECT_ROOT"

# ---------------------------------------------------------------------------
# Pretty output
# ---------------------------------------------------------------------------
if [[ -t 1 ]] && [[ "${NO_COLOR:-}" == "" ]]; then
  C_RED=$'\033[31m'; C_GRN=$'\033[32m'; C_YEL=$'\033[33m'
  C_BLU=$'\033[34m'; C_CYN=$'\033[36m'; C_DIM=$'\033[2m'
  C_BLD=$'\033[1m'; C_RST=$'\033[0m'
else
  C_RED=''; C_GRN=''; C_YEL=''; C_BLU=''; C_CYN=''
  C_DIM=''; C_BLD=''; C_RST=''
fi

log()   { printf "%s\n" "$*"; }
info()  { printf "${C_CYN}==>${C_RST} %s\n" "$*"; }
ok()    { printf "${C_GRN} ok ${C_RST} %s\n" "$*"; }
warn()  { printf "${C_YEL}warn${C_RST} %s\n" "$*" >&2; }
err()   { printf "${C_RED}fail${C_RST} %s\n" "$*" >&2; }
fatal() { err "$*"; exit 1; }

# ---------------------------------------------------------------------------
# Env / catalog
# ---------------------------------------------------------------------------
ENV_FILE="$PROJECT_ROOT/.env"
ENV_EXAMPLE="$PROJECT_ROOT/.env.example"
CATALOG_FILE="$PROJECT_ROOT/catalog.json"

load_env() {
  if [[ ! -f "$ENV_FILE" && -f "$ENV_EXAMPLE" ]]; then
    cp "$ENV_EXAMPLE" "$ENV_FILE"
    info "Created .env from .env.example"
  fi
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
}

env_set() {
  local key="$1" val="$2"
  if grep -q "^${key}=" "$ENV_FILE"; then
    sed -i "s|^${key}=.*|${key}=${val}|" "$ENV_FILE"
  else
    echo "${key}=${val}" >> "$ENV_FILE"
  fi
}

catalog_keys()  { jq -r 'keys[]' "$CATALOG_FILE"; }
catalog_has()   { jq -e --arg k "$1" 'has($k)' "$CATALOG_FILE" >/dev/null 2>&1; }
catalog_field() { jq -r --arg k "$1" --arg f "$2" '.[$k][$f] // empty' "$CATALOG_FILE"; }

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
require_cmd() {
  command -v "$1" >/dev/null || fatal "$1 not found in PATH. Install it and retry."
}

require_running() {
  docker compose ps llama-server --format '{{.Status}}' 2>/dev/null \
    | grep -qE 'Up.*healthy' \
    || fatal "Stack is not running. Start with: ./vello-llama-local up"
}

stack_running() {
  docker compose ps llama-server --format '{{.Status}}' 2>/dev/null | grep -q 'Up'
}

# ---------------------------------------------------------------------------
# Commands: lifecycle
# ---------------------------------------------------------------------------
cmd_install() {
  info "1/5 Checking prerequisites"
  for c in docker jq curl nvidia-smi; do require_cmd "$c"; done
  docker info >/dev/null 2>&1 || \
    fatal "Docker daemon not accessible. Add yourself to the docker group: sudo usermod -aG docker \$USER"
  ok "all prerequisites present"

  info "2/5 nvidia-container-toolkit"
  if dpkg -l nvidia-container-toolkit >/dev/null 2>&1; then
    ok "already installed ($(dpkg-query -W -f='${Version}' nvidia-container-toolkit))"
  else
    install_nvidia_toolkit
  fi

  info "3/5 GPU passthrough smoke test"
  if docker run --rm --gpus all nvidia/cuda:12.4.0-base-ubuntu22.04 nvidia-smi -L >/dev/null 2>&1; then
    ok "Docker can reach the GPU"
  else
    fatal "Docker cannot reach the GPU. Try: sudo systemctl restart docker"
  fi

  info "4/5 Build llama-server image (10-15 min one-time, cached after)"
  if docker image inspect vello/llama-server-cuda:12.4 >/dev/null 2>&1; then
    ok "image already built"
  else
    docker compose build llama-server
    ok "image built"
  fi

  info "5/5 Default model + start stack"
  load_env
  local default_name="${LOCAL_LLM_DEFAULT_MODEL:-qwen2.5-7b}"
  local default_file
  default_file=$(catalog_field "$default_name" "file")
  if [[ ! -f "$PROJECT_ROOT/models/$default_file" ]]; then
    cmd_models_pull "$default_name"
  fi
  cmd_models_use "$default_name" --no-restart
  cmd_up

  echo
  printf "${C_GRN}${C_BLD}Installation complete.${C_RST}\n"
  log "  Web UI: http://localhost:${WEBUI_PORT:-3000}"
  log "  API:    http://localhost:${LLAMA_PORT:-8080}/v1"
  log "  Try:    ./vello-llama-local test"
}

install_nvidia_toolkit() {
  info "installing nvidia-container-toolkit (sudo required)"
  curl -fsSL https://nvidia.github.io/libnvidia-container/gpgkey \
    | sudo gpg --batch --yes --dearmor \
        -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg
  curl -fsSL https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list \
    | sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' \
    | sudo tee /etc/apt/sources.list.d/nvidia-container-toolkit.list >/dev/null
  sudo apt-get update -y
  sudo apt-get install -y nvidia-container-toolkit
  sudo nvidia-ctk runtime configure --runtime=docker
  sudo systemctl restart docker
  ok "installed and Docker restarted"
}

cmd_up() {
  load_env
  local f="${LLAMA_MODEL_FILE:-}"
  [[ -z "$f" ]] && fatal "LLAMA_MODEL_FILE not set in .env. Run: ./vello-llama-local models use <name>"
  [[ -f "$PROJECT_ROOT/models/$f" ]] || fatal "Model file missing: models/$f. Run: ./vello-llama-local models pull <name>"

  docker compose up -d
  echo
  log "  Web UI: ${C_BLU}http://localhost:${WEBUI_PORT:-3000}${C_RST}"
  log "  API:    ${C_BLU}http://localhost:${LLAMA_PORT:-8080}/v1${C_RST}"
  log "  Model:  ${LLAMA_MODEL_ALIAS:-?} (${f})"
  log "  ${C_DIM}Model loads in ~30-60s on first start. Watch with: ./vello-llama-local logs -f${C_RST}"
}

cmd_down()    { docker compose down; }
cmd_restart() { cmd_down; cmd_up; }
cmd_status()  { docker compose ps --format 'table {{.Name}}\t{{.Status}}\t{{.Ports}}'; }
cmd_logs()    { docker compose logs --tail=200 "$@"; }

cmd_health() {
  load_env
  local p="${LLAMA_PORT:-8080}"
  if curl -fsS "http://localhost:$p/health" >/dev/null 2>&1; then
    ok "API healthy on :$p"
  else
    err "API not responding on :$p"
    exit 1
  fi
}

cmd_gpu() {
  command -v watch >/dev/null || fatal "'watch' not installed (apt install procps)"
  watch -n 1 nvidia-smi
}

cmd_config() {
  load_env
  printf "${C_BLD}vello-llama-local configuration${C_RST}\n"
  cat <<EOF
  Project root:    $PROJECT_ROOT
  Active model:    ${LLAMA_MODEL_FILE:-(none)}
  Model alias:     ${LLAMA_MODEL_ALIAS:-(none)}
  Context size:    ${LLAMA_CTX:-32768}
  GPU layers:      ${LLAMA_NGL:-99}
  Threads:         ${LLAMA_THREADS:-6}
  Batch / ubatch:  ${LLAMA_BATCH:-2048} / ${LLAMA_UBATCH:-512}
  API port:        ${LLAMA_PORT:-8080}
  Web UI port:     ${WEBUI_PORT:-3000}
  Web UI auth:     ${WEBUI_AUTH:-False}
EOF
}

# ---------------------------------------------------------------------------
# Commands: bench / test
# ---------------------------------------------------------------------------
cmd_bench() {
  require_running
  load_env
  local port="${LLAMA_PORT:-8080}"
  local prompt="${1:-Write a long essay about transformer neural networks.}"
  local n="${2:-256}"

  info "benchmark on :$port (n_predict=$n)"
  local req
  req=$(jq -nc --arg p "$prompt" --argjson n "$n" \
         '{prompt:$p,n_predict:$n,cache_prompt:false,stream:false}')
  local res
  res=$(curl -fsS "http://localhost:$port/completion" \
          -H 'Content-Type: application/json' -d "$req")
  echo "$res" | jq -r '
    .timings // {} |
    "  prompt eval:  \(.prompt_n // 0) tokens / \((.prompt_ms // 0)/1000)s = \(.prompt_per_second // 0 | round) tok/s",
    "  generation:   \(.predicted_n // 0) tokens / \((.predicted_ms // 0)/1000)s = \(.predicted_per_second // 0 | round) tok/s"
  '
}

cmd_test() {
  require_running
  load_env
  local port="${LLAMA_PORT:-8080}"
  local model="${LLAMA_MODEL_ALIAS:-local-model}"

  info "tool-calling test on $model"
  local req
  req=$(jq -nc --arg m "$model" '{
    model: $m,
    messages: [
      {role:"system", content:"You use tools when external data is needed."},
      {role:"user",   content:"What is the weather in Paris right now? Use the tool."}
    ],
    tools: [{
      type: "function",
      function: {
        name: "get_weather",
        description: "Get current weather for a city",
        parameters: {
          type: "object",
          properties: { city: {type:"string", description:"City name"} },
          required: ["city"]
        }
      }
    }],
    tool_choice: "auto",
    max_tokens: 200,
    temperature: 0
  }')
  local res
  res=$(curl -fsS "http://localhost:$port/v1/chat/completions" \
          -H 'Content-Type: application/json' -d "$req")
  local name args text
  name=$(echo "$res" | jq -r '.choices[0].message.tool_calls[0].function.name // empty')
  args=$(echo "$res" | jq -r '.choices[0].message.tool_calls[0].function.arguments // empty')
  text=$(echo "$res" | jq -r '.choices[0].message.content // empty')

  if [[ -n "$name" ]]; then
    ok "tool_call detected"
    log "  name: $name"
    log "  args: $args"
    log
    ok "tool calling works on this model"
  else
    err "model did not return a tool_call"
    log "  raw content: $text"
    log
    log "Tip: this model's chat template may not support tool calling."
    log "Try a tools-friendly model: ./vello-llama-local models pull qwen2.5-7b"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Commands: models
# ---------------------------------------------------------------------------
cmd_models() {
  local sub="${1:-list}"
  shift || true
  case "$sub" in
    list|ls)        cmd_models_list "$@" ;;
    pull|add|get)   cmd_models_pull "$@" ;;
    use|switch|set) cmd_models_use "$@" ;;
    rm|remove|del)  cmd_models_rm "$@" ;;
    *) fatal "Unknown subcommand: models $sub. Run: ./vello-llama-local help" ;;
  esac
}

cmd_models_list() {
  load_env
  local active="${LLAMA_MODEL_FILE:-}"

  printf "${C_BLD}%-22s %-12s %-9s %s${C_RST}\n" "NAME" "STATUS" "SIZE" "DESCRIPTION"
  while read -r key; do
    local file size desc status
    file=$(catalog_field "$key" "file")
    size=$(catalog_field "$key" "size")
    desc=$(catalog_field "$key" "description")
    if [[ -f "$PROJECT_ROOT/models/$file" ]]; then
      if [[ "$file" == "$active" ]]; then
        status="${C_GRN}active${C_RST}"
      else
        status="downloaded"
      fi
    else
      status="${C_DIM}—${C_RST}"
    fi
    printf "  %-22s %-21b %-9s %s\n" "$key" "$status" "$size" "$desc"
  done < <(catalog_keys | sort)

  # Show GGUFs that are on disk but not in catalog
  local extras=()
  for f in "$PROJECT_ROOT"/models/*.gguf; do
    [[ -e "$f" ]] || continue
    local fname; fname=$(basename "$f")
    local in_catalog=false
    while read -r k; do
      [[ "$(catalog_field "$k" file)" == "$fname" ]] && in_catalog=true && break
    done < <(catalog_keys)
    [[ "$in_catalog" == false ]] && extras+=("$fname")
  done
  if [[ ${#extras[@]} -gt 0 ]]; then
    echo
    info "Other GGUFs in models/ (not in catalog)"
    for f in "${extras[@]}"; do log "  $f"; done
  fi
}

cmd_models_pull() {
  local arg="${1:-}"
  [[ -z "$arg" ]] && fatal "Usage: ./vello-llama-local models pull <name|hf-repo/file.gguf>"

  local repo file size desc name
  if [[ "$arg" == */*.gguf ]]; then
    # Arbitrary HuggingFace path: <user>/<repo>/<file.gguf>
    file=$(basename "$arg")
    repo=$(dirname "$arg")
    name=$(echo "$file" | sed 's/\.gguf$//' | tr '[:upper:]' '[:lower:]')
    size="?"
    desc="custom HF model"
  elif catalog_has "$arg"; then
    repo=$(catalog_field "$arg" "repo")
    file=$(catalog_field "$arg" "file")
    size=$(catalog_field "$arg" "size")
    desc=$(catalog_field "$arg" "description")
    name="$arg"
  else
    err "Unknown model: $arg"
    log "  Catalog: ./vello-llama-local models list"
    log "  Or use a full HF path: ./vello-llama-local models pull <user>/<repo>/<file.gguf>"
    exit 1
  fi

  mkdir -p "$PROJECT_ROOT/models"
  local dest="$PROJECT_ROOT/models/$file"

  info "pulling $name"
  log "  repo: $repo"
  log "  file: $file"
  log "  size: $size"

  if [[ -f "$dest" ]]; then
    ok "already downloaded ($(du -h "$dest" | cut -f1))"
  else
    local url="https://huggingface.co/${repo}/resolve/main/${file}?download=true"
    curl -L --fail --progress-bar \
      -H "User-Agent: vello-llama-local/$VERSION" \
      -o "$dest.partial" "$url"
    mv "$dest.partial" "$dest"
    ok "downloaded ($(du -h "$dest" | cut -f1))"
  fi

  echo
  log "Activate with: ${C_CYN}./vello-llama-local models use $name${C_RST}"
}

cmd_models_use() {
  local name="${1:-}"
  local restart="yes"
  [[ "${2:-}" == "--no-restart" ]] && restart="no"
  [[ -z "$name" ]] && fatal "Usage: ./vello-llama-local models use <name>"

  load_env

  local file
  if catalog_has "$name"; then
    file=$(catalog_field "$name" "file")
  else
    # Try matching a GGUF file in models/
    for f in "$PROJECT_ROOT"/models/*.gguf; do
      [[ -e "$f" ]] || continue
      local fname; fname=$(basename "$f")
      if [[ "$fname" == "$name" || "${fname%.gguf}" == "$name" ]]; then
        file="$fname"
        break
      fi
    done
    [[ -z "${file:-}" ]] && fatal "Unknown model: $name. Try: ./vello-llama-local models list"
  fi

  if [[ ! -f "$PROJECT_ROOT/models/$file" ]]; then
    fatal "Not downloaded: models/$file. Run: ./vello-llama-local models pull $name"
  fi

  env_set LLAMA_MODEL_FILE "$file"
  env_set LLAMA_MODEL_ALIAS "${name}-local"
  ok "active model set to $name (alias: ${name}-local)"

  if [[ "$restart" == "yes" ]] && stack_running; then
    info "restarting stack to load new model..."
    cmd_restart
  fi
}

cmd_models_rm() {
  local name="${1:-}"
  [[ -z "$name" ]] && fatal "Usage: ./vello-llama-local models rm <name>"

  local file
  if catalog_has "$name"; then
    file=$(catalog_field "$name" "file")
  else
    file="$name"
  fi
  local target="$PROJECT_ROOT/models/$file"
  [[ -f "$target" ]] || fatal "Model file not found: models/$file"

  load_env
  if [[ "${LLAMA_MODEL_FILE:-}" == "$file" ]]; then
    fatal "$file is the active model. Switch first: ./vello-llama-local models use <other>"
  fi

  rm -f "$target"
  ok "removed models/$file"
}

# ---------------------------------------------------------------------------
# Commands: clients
# ---------------------------------------------------------------------------
cmd_clients() {
  local sub="${1:-install}"
  case "$sub" in
    install) cmd_clients_install ;;
    *) fatal "Unknown subcommand: clients $sub" ;;
  esac
}

cmd_clients_install() {
  info "Installing CLI clients (opencode + crush)"

  if command -v opencode >/dev/null; then
    ok "opencode already installed"
  elif command -v npm >/dev/null; then
    npm install -g opencode-ai
  else
    curl -fsSL https://opencode.ai/install | bash
  fi

  if command -v crush >/dev/null; then
    ok "crush already installed"
  elif command -v go >/dev/null; then
    go install github.com/charmbracelet/crush@latest
    log "  ensure \$(go env GOPATH)/bin is in PATH"
  elif command -v npm >/dev/null; then
    npm install -g @charmland/crush
  else
    warn "no installer for crush found — see https://github.com/charmbracelet/crush"
  fi

  local cfg_root="${XDG_CONFIG_HOME:-$HOME/.config}"
  for f in opencode crush; do
    local dst_dir="$cfg_root/$f"
    mkdir -p "$dst_dir"
    local dst="$dst_dir/$f.json"
    if [[ -f "$dst" ]]; then
      cp "$dst" "$dst.bak"
      info "backed up $dst → $dst.bak"
    fi
    cp "$PROJECT_ROOT/clients/$f.json" "$dst"
    ok "installed $f config: $dst"
  done

  echo
  log "Run: ${C_CYN}opencode${C_RST}  or  ${C_CYN}crush${C_RST}"
}

# ---------------------------------------------------------------------------
# Commands: build / nuke
# ---------------------------------------------------------------------------
cmd_build() {
  docker compose build "$@" llama-server
}

cmd_nuke() {
  warn "This will stop and remove containers, volumes, and the llama-server image."
  warn "Models in ./models/ are kept. Press Ctrl-C to abort."
  if [[ -t 0 ]]; then
    read -rp "Continue? [y/N] " -n 1 reply
    echo
    [[ "$reply" =~ ^[Yy]$ ]] || { log "aborted"; exit 0; }
  fi
  docker compose down -v --rmi all --remove-orphans || true
  ok "stack removed"
  echo
  log "Optional follow-ups:"
  log "  rm -f models/*.gguf                          # delete downloaded models"
  log "  sudo apt purge nvidia-container-toolkit      # remove GPU toolkit"
  log "  rm -rf '$PROJECT_ROOT'                       # remove this project"
}

# ---------------------------------------------------------------------------
# Help / version
# ---------------------------------------------------------------------------
cmd_version() { echo "vello-llama-local v$VERSION"; }

cmd_help() {
  cat <<EOF
${C_BLD}vello-llama-local${C_RST} v$VERSION — self-hosted LLM stack on your GPU

${C_CYN}USAGE${C_RST}
  ./vello-llama-local <command> [args]

${C_CYN}LIFECYCLE${C_RST}
  install                One-shot setup: deps, GPU toolkit, image build, default model, start
  up                     Start the stack (llama-server + Open WebUI)
  down                   Stop the stack
  restart                Restart the stack
  status                 Show containers + health
  logs [-f]              Show container logs (-f to follow)
  health                 Quick API health check
  gpu                    Live nvidia-smi (Ctrl-C to exit)
  config                 Show effective configuration
  bench [PROMPT] [N]     Throughput benchmark (default N=256 tokens)
  test                   Tool-calling validation

${C_CYN}MODELS${C_RST}
  models list                       List catalog + status (downloaded / active)
  models pull <name|hf-path>        Download a model
  models use  <name>                Switch active model and restart
  models rm   <name>                Delete a downloaded model

${C_CYN}CLIENTS${C_RST}
  clients install                   Install opencode + crush, copy configs

${C_CYN}MAINTENANCE${C_RST}
  build [--no-cache]                Rebuild the llama-server image
  nuke                              Remove containers, volumes, images
  version                           Print version
  help                              This message

${C_CYN}EXAMPLES${C_RST}
  ./vello-llama-local install                                  # first-time setup
  ./vello-llama-local models pull qwen2.5-coder-7b
  ./vello-llama-local models use qwen2.5-coder-7b
  ./vello-llama-local models pull bartowski/Hermes-3-Llama-3.1-8B-GGUF/Hermes-3-Llama-3.1-8B-Q5_K_M.gguf
  ./vello-llama-local bench "Write a poem about the sea" 200

${C_CYN}URLS (when running)${C_RST}
  Web UI:      http://localhost:\${WEBUI_PORT:-3000}
  API:         http://localhost:\${LLAMA_PORT:-8080}/v1
  llama UI:    http://localhost:\${LLAMA_PORT:-8080}

EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    install)              cmd_install "$@" ;;
    up|start)             cmd_up "$@" ;;
    down|stop)            cmd_down "$@" ;;
    restart)              cmd_restart "$@" ;;
    status|ps)            cmd_status "$@" ;;
    logs)                 cmd_logs "$@" ;;
    health)               cmd_health "$@" ;;
    gpu)                  cmd_gpu "$@" ;;
    config)               cmd_config "$@" ;;
    bench)                cmd_bench "$@" ;;
    test)                 cmd_test "$@" ;;
    models)               cmd_models "$@" ;;
    clients)              cmd_clients "$@" ;;
    build)                cmd_build "$@" ;;
    nuke|destroy)         cmd_nuke "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help|"")    cmd_help ;;
    *) err "unknown command: $cmd"; cmd_help; exit 1 ;;
  esac
}

main "$@"
